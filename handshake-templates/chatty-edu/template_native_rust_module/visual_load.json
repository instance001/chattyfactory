{
  "kind": "native_window",
  "auto_launch": true,
  "window_title_contains": "Template Native Rust Module",
  "notes": "This starter keeps native app state inside the module folder and only uses the bridge for Chatty-EDU handoff.",
  "build": {
    "program": "cargo",
    "args": ["build"],
    "cwd": "."
  },
  "launch": {
    "program": "target/debug/template_native_rust_module.exe",
    "cwd": "."
  }
}
