step 2: Update smoke_check.py to check for usage message | write_file smoke_check.py | contents: from pathlib import Path\nimport sys\n\nINTENT_KEYWORDS = ["dashboard", "monitor", "window"]\ndef main() -> int:\n    html_path = Path("index.html")\n    if not html_path.exists():\n        raise SystemExit("index.html missing")\n    text = html_path.read_text(encoding="utf-8").lower()\n    required = ["<html", "</html>", "<body", "</body>"]\n    missing = [needle for needle in required if needle not in text]\n    if missing:\n        raise SystemExit("missing required html structure: " + ", ".join(missing))\n    has_behavior = "<script" in text or "<form" in text or "button" in text or "canvas" in text\n    if not has_behavior:\n        raise SystemExit("page has no obvious interactive/behavior surface")\n    missing_keywords = [word for word in INTENT_KEYWORDS if word not in text]\n    if len(missing_keywords) > max(2, len(INTENT_KEYWORDS) // 2):\n        raise SystemExit("page appears weakly tied to request; missing keywords: " + ", ".join(missing_keywords))\n    if len(sys.argv) > 1 and sys.argv[1] == "--help":\n        print("usage: smoke_check.py [--help]")\n        return 0\n    print("usage: smoke_check.py [--help]")\n    return 0\nif __name__ == "__main__":\n    raise SystemExit(main()) | verify: exists smoke_check.py
