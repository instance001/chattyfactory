{
  "kind": "native_window",
  "auto_launch": true,
  "window_title_contains": "ChattyFactory",
  "notes": "If the binary is missing, use Build UI once and then relaunch the tab.",
  "build": {
    "program": "cargo",
    "args": ["build", "-p", "chattyfactory_gui"],
    "cwd": "."
  },
  "launch": {
    "program": "target/debug/chattyfactory_gui.exe",
    "cwd": "."
  }
}
